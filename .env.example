# Supabase MCP — personal access token i project reference.
# Skopiuj ten plik jako `.env` i uzupełnij wartości. Przed startem Claude Code
# załaduj zmienne do sesji shell:
#   set -a; source .env; set +a; claude
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Slack MCP — bot token aplikacji Slack (zaczyna się od `xoxb-`) oraz ID workspace'u
# (zaczyna się od `T...`, np. `T01AB2CD3EF`). Token generujesz przy instalacji
# aplikacji Slack do workspace'u; Team ID znajdziesz w URL-u web-clienta Slacka
# (`app.slack.com/client/T.../...`) albo przez wywołanie `auth.test` Slack API.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
SLACK_CHANNEL_ID=
